# TradeGym AI local/deployment configuration

# App
APP_ENV=local
APP_BASE_URL=http://localhost:4273
PORT=4273
COOKIE_SECURE=false

# Storage
TRADEGYM_SQLITE_PATH=./data/tradegym.sqlite
TRADEGYM_SEED_PATH=./data/db.json

# AI coach
# mock is the safe local fallback. External providers must keep outputs education-only.
AI_COACH_PROVIDER=mock
# AI_COACH_API_KEY=

# Email
# local exposes verification/reset tokens for local demos. Production must use a real provider.
EMAIL_PROVIDER=local
EMAIL_FROM=no-reply@tradegym.local
EMAIL_EXPOSE_LOCAL_TOKENS=true
# EMAIL_API_KEY=

# Payment
# local is a simulated state machine. Production must verify webhook signatures.
PAYMENT_PROVIDER=local
# PAYMENT_WEBHOOK_SECRET=

# Market/news/content pipeline
# demo/rule-based modes are for education prototypes only.
# Optional public-preview modes for data-governance testing only:
# MARKET_DATA_PROVIDER=stooq_public
# NEWS_PROVIDER=gdelt_public
# Public preview data is not production-cleared commercial training data.
MARKET_DATA_PROVIDER=demo
# MARKET_DATA_API_KEY=
NEWS_PROVIDER=demo
# NEWS_API_KEY=
QUESTION_GENERATOR_PROVIDER=rule-based
# QUESTION_GENERATOR_API_KEY=
KNOWLEDGE_DISTILLER_PROVIDER=rule-based
# KNOWLEDGE_DISTILLER_API_KEY=

# Audit
# false means operational logs only, not an immutable ledger.
AUDIT_IMMUTABLE_LEDGER=false
