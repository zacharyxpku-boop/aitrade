{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "styles.css",
          "app.js",
          "privacy.html",
          "terms.html",
          "risk-disclosure.html",
          "data/db.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "APP_ENV": "vercel",
    "TRADEGYM_SQLITE_PATH": "/tmp/tradegym.sqlite"
  }
}
