{
  "version": 2,
  "builds": [
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "trial-flow-state.js",
      "use": "@vercel/static"
    },
    {
      "src": "training-flow-state.js",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "styles.css",
          "app.js",
          "trial-flow-state.js",
          "training-flow-state.js",
          "privacy.html",
          "terms.html",
          "risk-disclosure.html",
          "data/db.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/trial-flow-state.js",
      "dest": "/trial-flow-state.js"
    },
    {
      "src": "/training-flow-state.js",
      "dest": "/training-flow-state.js"
    },
    {
      "src": "/(trial|friend-trial)/(styles.css|app.js|trial-flow-state.js|training-flow-state.js)",
      "dest": "/$2"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "APP_ENV": "vercel",
    "APP_BASE_URL": "https://aitrade-ll84.vercel.app",
    "COOKIE_SECURE": "true",
    "TRADEGYM_SQLITE_PATH": "/tmp/tradegym.sqlite"
  }
}
