      "noSpeechProb": 0.058639902621507645
    },
    {
      "index": 53,
      "start": 205.6,
      "end": 206.8,
      "text": "你怎麼知道的",
      "avgLogprob": -0.2322908728680712,
      "noSpeechProb": 0.058639902621507645
    },
    {
      "index": 54,
      "start": 207.68,
      "end": 210.96,
      "text": "平經驗,這就是包頭皮的難點之一",
