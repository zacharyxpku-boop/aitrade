    {
      "index": 4,
      "start": 12.16,
      "end": 14.36,
      "text": "並談談如何管理交易",
      "avgLogprob": -0.3204451070229212,
      "noSpeechProb": 0.04320742189884186
    },
    {
      "index": 5,
      "start": 14.36,
      "end": 25.31,
      "text": "移民你指數以大空頭開盤",
