      "noSpeechProb": 0.058639902621507645
    },
    {
      "index": 57,
      "start": 218.88,
      "end": 221.84,
      "text": "如果你在這根推線的高點上方買入一格",
      "avgLogprob": -0.2322908728680712,
      "noSpeechProb": 0.058639902621507645
    },
    {
      "index": 58,
      "start": 221.84,
      "end": 224.8,
      "text": "你的實際風險就是在下方買入一格",
